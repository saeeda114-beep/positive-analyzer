/* ── SUMMARY ── */
function buildSum(t){
  const st=parsed[t].students, n=st.length;
  const avgAll=(st.reduce((a,b)=>a+b.avg,0)/n).toFixed(1);
  const ex=st.filter(s=>s.generalGrade==='ممتاز').length;
  const need=st.filter(s=>['مقبول','ضعيف'].includes(s.generalGrade)).length;
  const first=st[0], last=st[n-1];
  return `<div class="sc-grid">
    <div class="sc"><div class="sc-l">عدد الطلاب</div><div class="sc-v">${n}</div><div class="sc-n">طالب مرصود</div></div>
    <div class="sc gd"><div class="sc-l">المتوسط العام</div><div class="sc-v">${avgAll}%</div><div class="sc-n">متوسط الصف</div></div>
    <div class="sc gn"><div class="sc-l">الأول</div><div class="sc-v">${first.avg}%</div><div class="sc-n">${first.name.split(' ').slice(0,2).join(' ')}</div></div>
    <div class="sc"><div class="sc-l">ممتاز</div><div class="sc-v">${ex}</div><div class="sc-n">${((ex/n)*100).toFixed(0)}%</div></div>
    <div class="sc rd"><div class="sc-l">يحتاج دعم</div><div class="sc-v">${need}</div><div class="sc-n">مقبول أو أدنى</div></div>
    <div class="sc pu"><div class="sc-l">الأدنى</div><div class="sc-v">${last.avg}%</div><div class="sc-n">${last.name.split(' ').slice(0,2).join(' ')}</div></div>
  </div>
  <div class="ch-grid" style="margin-top:12px">
    <div class="ch-card"><h4>توزيع التقديرات</h4><div class="ch-wrap"><canvas id="${t}-chG"></canvas></div></div>
    <div class="ch-card"><h4>متوسط المواد الأساسية</h4><div class="ch-wrap ch-h160"><canvas id="${t}-chS"></canvas></div></div>
  </div>`;
}

/* ── TOP 10 ── */
function buildTop(t){
  const st=parsed[t].students;
  const rc=['r1','r2','r3'],md=['🥇','🥈','🥉'];
  return `<div class="sec">🏆 العشرة الأوائل</div>
