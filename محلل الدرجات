<!DOCTYPE html>
<html lang="ar" dir="rtl">
<head>
<meta charset="UTF-8">
<title>محلل درجات الطلاب</title>
<script src="https://cdnjs.cloudflare.com/ajax/libs/xlsx/0.18.5/xlsx.full.min.js"></script>
<script src="https://cdnjs.cloudflare.com/ajax/libs/Chart.js/4.4.1/chart.umd.min.js"></script>
<style>
@import url('https://fonts.googleapis.com/css2?family=Tajawal:wght@300;400;500;700;800;900&display=swap');
:root{--dk:#1a3a4a;--tl:#1d5c6e;--gn:#2e7d52;--gd:#c8973a;--rd:#c0392b;--pu:#7d3c98;
  --bg:#f0f4f6;--sf:#fff;--br:#d4dde4;--tx:#1a2a35;--mu:#6b808c;--r:10px;}
*{margin:0;padding:0;box-sizing:border-box;}
body{font-family:'Tajawal',sans-serif;background:var(--bg);color:var(--tx);font-size:14px;}
.topbar{background:var(--dk);padding:10px 22px;display:flex;align-items:center;justify-content:space-between;position:sticky;top:0;z-index:100;box-shadow:0 2px 8px rgba(0,0,0,.2);}
.brand{color:rgba(255,255,255,.85);font-size:14px;font-weight:700;}
.bar-btns{display:flex;gap:8px;}
.ab{display:inline-flex;align-items:center;gap:5px;padding:7px 16px;border-radius:20px;font-family:'Tajawal',sans-serif;font-size:13px;font-weight:500;cursor:pointer;transition:all .15s;border:none;}
.abg{background:rgba(255,255,255,.1);color:white;border:1px solid rgba(255,255,255,.2);}
.abg:hover{background:rgba(255,255,255,.2);}
.abgold{background:var(--gd);color:white;}
.abgold:hover{background:#b5832e;}
.ab:disabled{opacity:.4;cursor:default;pointer-events:none;}
.sbar{background:var(--sf);border-bottom:2px solid var(--br);padding:9px 22px;display:flex;align-items:center;gap:10px;flex-wrap:wrap;}
.sg{display:flex;align-items:center;gap:6px;}
.sg label{font-size:12px;color:var(--mu);white-space:nowrap;}
.sg input{padding:6px 10px;border:1px solid var(--br);border-radius:8px;font-family:'Tajawal',sans-serif;font-size:13px;background:#f8fafb;color:var(--tx);outline:none;transition:all .15s;width:220px;}
.sg input:focus{border-color:var(--tl);}
.sbar-info{font-size:12px;color:var(--mu);padding:0 4px;}
.main{max-width:1200px;margin:0 auto;padding:20px;}
.up-panels{display:grid;grid-template-columns:1fr 1fr 1fr;gap:12px;margin-bottom:12px;}
.up-panel{background:var(--sf);border-radius:var(--r);border:1.5px solid var(--br);padding:18px;text-align:center;transition:border-color .2s;}
.up-panel h3{font-size:14px;font-weight:700;margin-bottom:8px;}
.dz{border:2px dashed var(--br);border-radius:8px;padding:18px 10px;cursor:pointer;transition:all .2s;margin-bottom:10px;}
.dz:hover,.dz.drag{border-color:var(--tl);background:#edf6f4;}
.dz.loaded{border-color:var(--gn);background:#e8f5ee;}
.dz-icon{font-size:28px;margin-bottom:5px;}
.dz p{font-size:12px;color:var(--mu);}
.dz p.ok{color:var(--gn);font-weight:700;}
.go{width:100%;padding:10px;border:none;border-radius:8px;font-family:'Tajawal',sans-serif;font-size:13px;font-weight:700;cursor:pointer;transition:all .2s;background:var(--br);color:var(--mu);}
.go.on{background:var(--tl);color:white;}
.go.on:hover{background:#17495a;}
.rpt{background:var(--sf);border-radius:var(--r);border:.5px solid var(--br);margin-bottom:20px;overflow:hidden;}
.rpt-hdr{background:var(--dk);color:white;padding:12px 18px;display:flex;align-items:center;justify-content:space-between;flex-wrap:wrap;gap:6px;}
.rpt-hdr h2{font-size:15px;font-weight:700;}
.rpt-hdr .meta{font-size:12px;opacity:.65;}
.rpt-body{padding:16px 18px;}
.tabs{display:flex;gap:3px;background:#f0f4f6;border-radius:8px;padding:4px;margin-bottom:14px;}
.tab{flex:1;padding:7px 6px;border-radius:6px;border:none;background:none;font-family:'Tajawal',sans-serif;font-size:12px;font-weight:500;cursor:pointer;color:var(--mu);transition:all .15s;}
.tab.on{background:var(--tl);color:white;}
.tc{display:none;}.tc.on{display:block;}
.sec{font-size:14px;font-weight:800;color:var(--dk);margin:14px 0 9px;display:flex;align-items:center;gap:7px;border-right:3px solid var(--tl);padding-right:9px;}
.sc-grid{display:grid;grid-template-columns:repeat(auto-fit,minmax(130px,1fr));gap:8px;margin-bottom:12px;}
.sc{background:#f7fafb;border-radius:8px;border:.5px solid var(--br);padding:12px 14px;position:relative;overflow:hidden;}
.sc::before{content:'';position:absolute;top:0;right:0;width:3px;height:100%;background:var(--tl);}
.sc.gd::before{background:var(--gd);}.sc.gn::before{background:var(--gn);}
.sc.rd::before{background:var(--rd);}.sc.pu::before{background:var(--pu);}
.sc-l{font-size:11px;color:var(--mu);margin-bottom:3px;}
.sc-v{font-size:22px;font-weight:900;color:var(--dk);}
.sc-n{font-size:10px;color:var(--mu);margin-top:2px;}
.top-grid{display:grid;grid-template-columns:repeat(auto-fill,minmax(230px,1fr));gap:8px;}
.tc-card{background:#f7fafb;border-radius:8px;border:.5px solid var(--br);padding:12px;display:flex;align-items:center;gap:10px;}
.tc-card.r1{border-color:#FFD700;background:#fffbeb;}
.tc-card.r2{border-color:#C0C0C0;background:#f8f8f8;}
.tc-card.r3{border-color:#CD7F32;background:#fdf5ec;}
.tc-card.rw{border-color:#f5b7b1;background:#fdf2f0;}
.tc-rk{font-size:20px;min-width:28px;text-align:center;}
.tc-nm{font-size:12px;font-weight:700;line-height:1.3;margin-bottom:3px;}
.tc-sc{font-size:16px;font-weight:900;color:var(--dk);}
.tc-sb{font-size:10px;color:var(--mu);}
.ch-grid{display:grid;grid-template-columns:1fr 1fr;gap:12px;}
.ch-card{background:#f7fafb;border-radius:8px;border:.5px solid var(--br);padding:14px;}
.ch-card h4{font-size:12px;font-weight:700;color:var(--dk);margin-bottom:10px;text-align:center;}
.ch-wrap{position:relative;height:190px;}
.ch-full{grid-column:1/-1;}
.ch-h160{height:160px;}
.stbl{width:100%;border-collapse:collapse;}
.stbl thead th{background:var(--dk);color:white;padding:8px 10px;font-size:11px;font-weight:600;text-align:center;}
.stbl thead th:first-child{text-align:right;}
.stbl tbody tr{border-bottom:.5px solid var(--br);}
.stbl tbody tr:nth-child(even){background:#f7fafb;}
.stbl td{padding:7px 10px;font-size:11px;text-align:center;}
.stbl td:first-child{text-align:right;font-weight:600;}
.dtbl-wrap{overflow-x:auto;border-radius:8px;border:.5px solid var(--br);}
.dtbl{width:100%;border-collapse:collapse;min-width:700px;}
.dtbl thead th{background:var(--dk);color:white;padding:8px 9px;font-size:10px;font-weight:600;text-align:center;white-space:nowrap;}
.dtbl thead th:nth-child(2){text-align:right;}
.dtbl tbody tr{border-bottom:.5px solid var(--br);}
.dtbl tbody tr:nth-child(even){background:#f7fafb;}
.dtbl tbody tr:hover{background:#e8f4f0;}
.dtbl td{padding:6px 9px;font-size:10px;text-align:center;}
.dtbl td:nth-child(2){text-align:right;font-weight:500;font-size:11px;}
.gp{display:inline-block;padding:1px 7px;border-radius:7px;font-size:10px;font-weight:600;}
.ex{background:#d4edda;color:#155724;}.vg{background:#d1ecf1;color:#0c5460;}
.gd2{background:#fff3cd;color:#856404;}.ac{background:#ffe5d0;color:#7d3c00;}.fl{background:#f8d7da;color:#721c24;}
.sf2{display:flex;gap:8px;margin-bottom:10px;flex-wrap:wrap;}
.sf2 input,.sf2 select{padding:7px 10px;border:1px solid var(--br);border-radius:16px;font-family:'Tajawal',sans-serif;font-size:12px;outline:none;background:white;}
.sf2 input:focus{border-color:var(--tl);}
.tbl-ft{padding:7px 10px;font-size:11px;color:var(--mu);text-align:center;border-top:.5px solid var(--br);}
.wtag{display:inline-block;background:#fdf2f0;border:1px solid #f5b7b1;padding:3px 8px;border-radius:10px;font-size:11px;margin:2px;}
.wtag b{color:var(--rd);}
.gap{margin-top:14px;}
.hidden{display:none!important;}

/* ── Print Dialog ── */
.print-overlay{display:none;position:fixed;inset:0;background:rgba(0,0,0,.55);z-index:999;align-items:center;justify-content:center;}
.print-overlay.open{display:flex;}
.print-box{background:#fff;border-radius:14px;padding:24px;width:520px;max-width:95vw;box-shadow:0 8px 40px rgba(0,0,0,.25);}
.print-box h3{font-size:16px;font-weight:800;color:var(--dk);margin-bottom:16px;border-bottom:2px solid var(--tl);padding-bottom:10px;}
.print-sections{display:grid;grid-template-columns:1fr 1fr;gap:8px;margin-bottom:18px;}
.ps-item{display:flex;align-items:center;gap:10px;background:#f7fafb;border:1.5px solid var(--br);border-radius:8px;padding:10px 14px;cursor:pointer;transition:all .15s;user-select:none;}
.ps-item:hover{border-color:var(--tl);background:#edf6f4;}
.ps-item.sel{border-color:var(--tl);background:#e0f0f6;}
.ps-item input[type=checkbox]{width:16px;height:16px;accent-color:var(--tl);cursor:pointer;flex-shrink:0;}
.ps-item .ps-icon{font-size:18px;}
.ps-item .ps-label{font-size:13px;font-weight:600;color:var(--dk);}
.ps-item .ps-sub{font-size:11px;color:var(--mu);}
.print-orient{display:flex;gap:8px;margin-bottom:16px;}
.orient-btn{flex:1;padding:8px;border:1.5px solid var(--br);border-radius:8px;background:#f7fafb;font-family:'Tajawal',sans-serif;font-size:13px;cursor:pointer;transition:all .15s;display:flex;align-items:center;justify-content:center;gap:6px;}
.orient-btn.sel{border-color:var(--tl);background:#e0f0f6;font-weight:700;}
.print-actions{display:flex;gap:8px;justify-content:flex-end;}
.pbtn{padding:9px 20px;border:none;border-radius:8px;font-family:'Tajawal',sans-serif;font-size:13px;font-weight:700;cursor:pointer;transition:all .15s;}
.pbtn-cancel{background:#f0f4f6;color:var(--mu);}
.pbtn-cancel:hover{background:var(--br);}
.pbtn-print{background:var(--tl);color:white;}
.pbtn-print:hover{background:#17495a;}
.pbtn-print:disabled{opacity:.4;cursor:default;}

/* ── Cover Page ── */
.cover-page{display:none;}

/* ── Cover Page ── */
.cover-page{display:none;}

/* ── Print base ── */
@media print {
  @page { size: A4 portrait; margin: 14mm 12mm; }
  * { -webkit-print-color-adjust: exact !important; print-color-adjust: exact !important; }
  body { background: white; font-size: 11px; }
  .topbar, .sbar, .up-panels, .tabs, .sf2, .print-overlay { display: none !important; }
  .main { padding: 0; max-width: 100%; }
  .cover-page {
    display: flex !important; flex-direction: column;
    align-items: center; justify-content: space-between;
    text-align: center;
    padding: 8mm 12mm 6mm; page-break-after: always;
    border: 2px solid #1a3a4a; box-sizing: border-box;
    /* يملأ الصفحة بغض النظر عن الاتجاه */
    height: calc(100vh - 4mm);
    max-height: calc(100vh - 4mm);
    overflow: hidden;
  }
  .cover-top { width: 100%; }
  .cover-title-box { border: 3px solid #1d5c6e; border-radius: 4mm; padding: 5mm 12mm; display: inline-block; margin: 6mm 0; -webkit-print-color-adjust:exact;print-color-adjust:exact; }
  .cover-title { font-size: 20pt; font-weight: 900; color: #1d5c6e; -webkit-print-color-adjust:exact;print-color-adjust:exact; }
  .cover-school { font-size: 15pt; font-weight: 800; color: #1a3a4a; margin-bottom: 3mm; }
  .cover-grade  { font-size: 13pt; color: #6b808c; margin-bottom: 8mm; }
  .cover-stats  { display: flex; justify-content: center; gap: 6mm; flex-wrap: wrap; margin: 4mm 0; }
  .cover-stat   { text-align: center; }
  .cover-stat .cv { font-size: 17pt; font-weight: 900; color: #1a3a4a; display: block; }
  .cover-stat .cl { font-size: 9pt; color: #6b808c; }
  .cover-footer { font-size: 9pt; color: #6b808c; border-top: 1px solid #d4dde4; padding-top: 3mm; width: 100%; }
  .tc { display: none; }
  .tc.print-include { display: block; page-break-before: always; }
  #rptYS, #rptES, #rptBoth { display: none; }
  .rpt { margin-bottom: 0; border: none; }
  .rpt-hdr { -webkit-print-color-adjust: exact; print-color-adjust: exact; }
  .sc::before { -webkit-print-color-adjust: exact; print-color-adjust: exact; }
  .gp { -webkit-print-color-adjust: exact; print-color-adjust: exact; }
  .stbl thead th, .dtbl thead th { -webkit-print-color-adjust: exact; print-color-adjust: exact; }
  .stbl tbody tr:nth-child(even), .dtbl tbody tr:nth-child(even) { background: #f7fafb !important; }
  .tc-card.r1,.tc-card.r2,.tc-card.r3,.tc-card.rw { -webkit-print-color-adjust: exact; print-color-adjust: exact; }
  .sc-grid,.top-grid { break-inside: avoid; }
  .tc-card,.sc { break-inside: avoid; }
  .stbl tbody tr,.dtbl tbody tr { break-inside: avoid; }
  .ch-wrap { height: 150px; }
  .ch-h160 { height: 120px; }
}
</style>
</head>
<body>

<div class="topbar">
  <span class="brand">📊 محلل درجات الطلاب — أعمال السنة / نهاية الفصل</span>
  <div class="bar-btns">
    <button class="ab abg" onclick="resetAll()">🔄 إعادة تعيين</button>
    <button class="ab abgold" id="btnPrint" onclick="openPrintDialog()" disabled>🖨️ خيارات الطباعة</button>
  </div>
</div>

<div class="sbar">
  <div class="sg"><label>🏫 اسم المدرسة</label>
    <input id="iSchool" placeholder="يُستخرج تلقائياً من الملف" readonly style="background:#f0f4f6;cursor:default;color:var(--tl);font-weight:600">
  </div>
  <div class="sg"><label>🎓 الصف الدراسي</label>
    <input id="iGrade" placeholder="يُستخرج تلقائياً" readonly style="background:#f0f4f6;cursor:default;color:var(--tl);font-weight:600;width:180px">
  </div>
  <span class="sbar-info">📌 تُستخرج المعلومات تلقائياً من الملف المرفوع</span>
</div>

<div class="main">
  <div class="up-panels">
    <div class="up-panel" id="panYS">
      <h3>📋 أعمال السنة</h3>
      <div class="dz" id="dzYS" onclick="document.getElementById('fYS').click()"
        ondragover="event.preventDefault();this.classList.add('drag')"
        ondragleave="this.classList.remove('drag')"
        ondrop="doDrop(event,'ys')">
        <div class="dz-icon">📂</div>
        <p id="lblYS">اضغط أو اسحب الملف</p>
        <input type="file" id="fYS" accept=".xlsx,.xls" style="display:none" onchange="onFile(this,'ys')">
      </div>
      <button class="go" id="btnYS" onclick="runReport('ys')" disabled>تحليل أعمال السنة</button>
    </div>
    <div class="up-panel" id="panES">
      <h3>📝 نهاية الفصل</h3>
      <div class="dz" id="dzES" onclick="document.getElementById('fES').click()"
        ondragover="event.preventDefault();this.classList.add('drag')"
        ondragleave="this.classList.remove('drag')"
        ondrop="doDrop(event,'es')">
        <div class="dz-icon">📂</div>
        <p id="lblES">اضغط أو اسحب الملف</p>
        <input type="file" id="fES" accept=".xlsx,.xls" style="display:none" onchange="onFile(this,'es')">
      </div>
      <button class="go" id="btnES" onclick="runReport('es')" disabled>تحليل نهاية الفصل</button>
    </div>
    <div class="up-panel">
      <h3>🔀 مقارنة التقريرين</h3>
      <p style="font-size:12px;color:var(--mu);padding:10px 0 14px;line-height:1.7">ارفع الملفين في الخانتين اليسرى ثم اضغط هنا للمقارنة الشاملة</p>
      <button class="go" id="btnBoth" onclick="runReport('both')" disabled>مقارنة التقريرين</button>
    </div>
  </div>

  <!-- COVER PAGE (print only) -->
  <div class="cover-page" id="coverPage">
    <div class="cover-top">
      <div class="cover-school" id="cvSchool">اسم المدرسة</div>
      <div class="cover-grade"  id="cvGrade"></div>
      <div class="cover-title-box">
        <div class="cover-title" id="cvTitle">تقرير الدرجات</div>
      </div>
    </div>
    <div class="cover-stats" id="cvStats"></div>
    <div class="cover-footer" id="cvFooter">
      التوجيه الطلابي — <span id="cvYear"></span>
    </div>
  </div>

  <div id="rptYS" class="hidden"></div>
  <div id="rptES" class="hidden"></div>
  <div id="rptBoth" class="hidden"></div>
</div>

<!-- ══ PRINT DIALOG ══ -->
<div class="print-overlay" id="printOverlay" onclick="if(event.target===this)closePrintDialog()">
  <div class="print-box">
    <h3>🖨️ خيارات الطباعة</h3>

    <div style="font-size:12px;color:var(--mu);margin-bottom:10px">اختر الأقسام التي تريد طباعتها:</div>
    <div class="print-sections" id="printSections">
      <!-- تُبنى ديناميكياً -->
    </div>

    <div style="font-size:12px;color:var(--mu);margin-bottom:8px">اتجاه الطباعة: <span style="font-size:11px;color:var(--rd)">(الكشف يُطبع أفقياً تلقائياً إذا اخترته وحده)</span></div>
    <div class="print-orient">
      <button class="orient-btn sel" id="oPortrait" onclick="setOrient('portrait')">📄 عمودي (Portrait)</button>
      <button class="orient-btn" id="oLandscape" onclick="setOrient('landscape')">📃 أفقي (Landscape)</button>
    </div>

    <div class="print-actions">
      <button class="pbtn pbtn-cancel" onclick="closePrintDialog()">إلغاء</button>
      <button class="pbtn pbtn-print" id="doPrintBtn" onclick="doPrint()">🖨️ طباعة</button>
    </div>
  </div>
</div>

<script>
/* ════ PRINT DIALOG ════ */
let printOrient = 'portrait';

const PRINT_SECTIONS = [
  {id:'sum', icon:'📊', label:'الملخص الإحصائي',  sub:'البطاقات والرسوم البيانية'},
  {id:'top', icon:'🏆', label:'العشرة الأوائل',    sub:'أعلى 10 طلاب'},
  {id:'weak',icon:'⚠️', label:'الضعف الدراسي',    sub:'الأدنى والمواد'},
  {id:'subj',icon:'📚', label:'تحليل المواد',      sub:'متوسطات ونسب كل مادة'},
  {id:'det', icon:'📄', label:'الكشف التفصيلي',   sub:'إذا اخترته وحده → أفقي تلقائياً'},
];

function openPrintDialog(){
  const sec = document.getElementById('printSections');
  const active = [];
  if(!document.getElementById('rptYS').classList.contains('hidden')) active.push('ys');
  if(!document.getElementById('rptES').classList.contains('hidden')) active.push('es');
  if(!active.length){ alert('لا يوجد تقرير معروض'); return; }

  sec.innerHTML = '';
  active.forEach(t=>{
    const lbl = t==='ys'?'أعمال السنة':'نهاية الفصل';
    const hdr = document.createElement('div');
    hdr.style.cssText='grid-column:1/-1;font-size:12px;font-weight:700;color:var(--tl);padding:4px 0 2px;border-bottom:1px solid var(--br);margin-bottom:2px;';
    hdr.textContent='📋 تقرير '+lbl;
    sec.appendChild(hdr);
    PRINT_SECTIONS.forEach(s=>{
      const el=document.createElement('label');
      el.className='ps-item sel';
      el.innerHTML=`<input type="checkbox" checked value="${t}-${s.id}">
        <span class="ps-icon">${s.icon}</span>
        <div><div class="ps-label">${s.label}</div><div class="ps-sub">${s.sub}</div></div>`;
      el.querySelector('input').addEventListener('change',e=>el.classList.toggle('sel',e.target.checked));
      sec.appendChild(el);
    });
  });

  if(!document.getElementById('rptBoth').classList.contains('hidden')){
    const hdr=document.createElement('div');
    hdr.style.cssText='grid-column:1/-1;font-size:12px;font-weight:700;color:var(--pu);padding:6px 0 2px;border-bottom:1px solid var(--br);margin-bottom:2px;';
    hdr.textContent='🔀 تقرير المقارنة';
    sec.appendChild(hdr);
    const el=document.createElement('label');
    el.className='ps-item sel';
    el.innerHTML=`<input type="checkbox" checked value="both-rpt">
      <span class="ps-icon">🔀</span>
      <div><div class="ps-label">تقرير المقارنة</div><div class="ps-sub">المقارنة الشاملة</div></div>`;
    el.querySelector('input').addEventListener('change',e=>el.classList.toggle('sel',e.target.checked));
    sec.appendChild(el);
  }
  // قسم صفحة الغلاف
  const coverHdr=document.createElement('div');
  coverHdr.style.cssText='grid-column:1/-1;font-size:12px;font-weight:700;color:var(--dk);padding:6px 0 2px;border-bottom:1px solid var(--br);margin-bottom:2px;';
  coverHdr.textContent='📄 إعدادات التقرير';
  sec.insertBefore(coverHdr, sec.firstChild);
  const coverEl=document.createElement('label');
  coverEl.className='ps-item sel';
  coverEl.style.cssText='grid-column:1/-1;';
  coverEl.innerHTML=`<input type="checkbox" checked value="cover-page">
