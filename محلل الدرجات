      </div></div>`).join('')}</div>`;
}

/* ── WEAK ── */
function buildWeak(t){
  const st=parsed[t].students, subjs=parsed[t].subjects;
  const bottom=[...st].reverse().slice(0,10);
  const acad=subjs.filter(s=>!ACAD_EXCL.has(s));
  const wRows=acad.map(subj=>{
    const ws2=st.filter(s=>s.subjects[subj]&&s.subjects[subj].score<60)
              .sort((a,b)=>a.subjects[subj].score-b.subjects[subj].score).slice(0,5);
    if(!ws2.length) return '';
    return `<tr><td>${subj}</td><td style="text-align:right">
      ${ws2.map(s=>`<span class="wtag">${s.name} <b>(${s.subjects[subj].score})</b></span>`).join('')}
    </td></tr>`;
  }).join('');
  return `<div class="sec">⚠️ الأدنى مجموعاً</div>
  <div class="top-grid">${bottom.map((s,i)=>`
    <div class="tc-card rw"><div class="tc-rk">${i+1}</div>
    <div><div class="tc-nm">${s.name}</div>
    <div class="tc-sc">${s.avg}%</div>
    <div class="tc-sb"><span class="gp ${gpCls(s.generalGrade)}">${s.generalGrade}</span></div>
    </div></div>`).join('')}
  </div>
  <div class="sec gap">⚠️ طلاب دون 60% في المواد الأكاديمية</div>
  ${wRows?`<div style="overflow-x:auto"><table class="stbl">
    <thead><tr><th>المادة</th><th style="text-align:right">الطلاب والدرجات</th></tr></thead>
    <tbody>${wRows}</tbody></table></div>`
  :'<p style="color:var(--gn);padding:10px 0">✅ لا يوجد طلاب دون 60% في المواد الأكاديمية</p>'}`;
}

/* ── SUBJECTS ── */
function buildSubj(t){
  const st=parsed[t].students, subjs=parsed[t].subjects;
  const rows=subjs.map(s=>{
    const sc=st.filter(x=>x.subjects[s]).map(x=>x.subjects[s].score);
    if(!sc.length) return '';
    const avg=(sc.reduce((a,b)=>a+b,0)/sc.length).toFixed(1);
    const ex=sc.filter(v=>v>=90).length, pass=sc.filter(v=>v>=60).length, fail=sc.filter(v=>v<50).length;
    const g=gradeLabel(parseFloat(avg));
    return `<tr><td>${s}</td><td><b>${avg}%</b></td>
      <td>${Math.max(...sc).toFixed(1)}</td><td>${Math.min(...sc).toFixed(1)}</td>
      <td>${ex}</td><td>${pass}</td>
      <td style="${fail>0?'color:var(--rd);font-weight:700':''}">${fail}</td>
      <td><span class="gp ${gpCls(g)}">${g}</span></td></tr>`;
  }).join('');
  return `<div style="overflow-x:auto"><table class="stbl">
    <thead><tr><th>المادة</th><th>المتوسط</th><th>الأعلى</th><th>الأدنى</th>
    <th>ممتاز</th><th>≥60%</th><th>دون50%</th><th>التقدير</th></tr></thead>
    <tbody>${rows}</tbody></table></div>`;
}

/* ── DETAIL ── */
function buildDet(t){
  const subjs=parsed[t].subjects.filter(s=>!SKIP_SUBJ.has(s));
  return `<div class="sf2">
    <input id="${t}-sq" placeholder="🔍 ابحث بالاسم..." oninput="filterDet('${t}')">
    <select id="${t}-gq" onchange="filterDet('${t}')">
      <option value="">كل التقديرات</option>
      <option>ممتاز</option><option>جيد جداً</option><option>جيد</option><option>مقبول</option><option>ضعيف</option>
    </select>
  </div>
  <div class="dtbl-wrap">
    <table class="dtbl">
      <thead><tr><th>#</th><th>اسم الطالب</th><th>المعدل</th><th>التقدير</th>
        ${subjs.map(s=>`<th>${s}</th>`).join('')}</tr></thead>
      <tbody id="${t}-db"></tbody>
    </table>
    <div class="tbl-ft" id="${t}-df"></div>
  </div>`;
}
function filterDet(t){
  const q=(document.getElementById(t+'-sq')?.value||'').trim();
  const gq=document.getElementById(t+'-gq')?.value||'';
  const subjs=parsed[t].subjects.filter(s=>!SKIP_SUBJ.has(s));
  let fl=parsed[t].students;
  if(q) fl=fl.filter(s=>s.name.includes(q));
  if(gq) fl=fl.filter(s=>s.generalGrade===gq);
  const body=document.getElementById(t+'-db'); if(!body) return;
  body.innerHTML=fl.map((s,i)=>`<tr>
    <td>${i+1}</td><td>${s.name}</td><td><b>${s.avg}%</b></td>
    <td><span class="gp ${gpCls(s.generalGrade)}">${s.generalGrade}</span></td>
    ${subjs.map(sj=>{
      const v=s.subjects[sj]; if(!v) return '<td>—</td>';
      const c=v.score<50?'color:var(--rd);font-weight:700':v.score>=90?'color:var(--gn);font-weight:700':'';
      return `<td style="${c}">${v.score}</td>`;
    }).join('')}</tr>`).join('');
  document.getElementById(t+'-df').textContent=fl.length+' من '+parsed[t].students.length+' طالب';
}

/* ════ CHARTS ════ */
const GRADES=['ممتاز','جيد جداً','جيد','مقبول','ضعيف'];
const GCOLS =['#2e7d52','#1d5c6e','#c8973a','#e67e22','#c0392b'];
function renderCH(t){
  const st=parsed[t].students;
  const ge=document.getElementById(t+'-chG');
  if(ge) CH[t].grade=new Chart(ge,{type:'doughnut',
    data:{labels:GRADES,datasets:[{data:GRADES.map(g=>st.filter(s=>s.generalGrade===g).length),backgroundColor:GCOLS,borderWidth:2,borderColor:'#fff'}]},
    options:{responsive:true,maintainAspectRatio:false,plugins:{legend:{position:'bottom',labels:{font:{family:'Tajawal',size:10},padding:6}}}}});
  const se=document.getElementById(t+'-chS');
  const avSubjs=ACAD_MAIN.filter(s=>parsed[t].subjects.includes(s));
  if(se&&avSubjs.length){
    const avgs=avSubjs.map(s=>{const sc=st.filter(x=>x.subjects[s]).map(x=>x.subjects[s].score);return sc.length?(sc.reduce((a,b)=>a+b,0)/sc.length).toFixed(1):0;});
    CH[t].subj=new Chart(se,{type:'bar',
      data:{labels:avSubjs,datasets:[{data:avgs,backgroundColor:['#1d5c6e','#2e7d52','#c8973a','#9b59b6','#1abc9c'],borderRadius:5}]},
      options:{responsive:true,maintainAspectRatio:false,plugins:{legend:{display:false}},
        scales:{x:{ticks:{font:{family:'Tajawal',size:9}}},y:{min:0,max:100,ticks:{font:{family:'Tajawal'}}}}}});
  }
  filterDet(t);
}

/* ════ BOTH ════ */
function buildBoth(){
  const ys=parsed.ys.students, es=parsed.es.students;
  const avgYS=(ys.reduce((a,b)=>a+b.avg,0)/ys.length).toFixed(1);
  const avgES=(es.reduce((a,b)=>a+b.avg,0)/es.length).toFixed(1);
  const top10YS=new Set(ys.slice(0,10).map(s=>s.name));
  const top10ES=new Set(es.slice(0,10).map(s=>s.name));
  const bothTop=[...top10YS].filter(n=>top10ES.has(n));
  const weakYS=new Set(ys.filter(s=>['مقبول','ضعيف'].includes(s.generalGrade)).map(s=>s.name));
  const weakES=new Set(es.filter(s=>['مقبول','ضعيف'].includes(s.generalGrade)).map(s=>s.name));
  const bothWeak=[...weakYS].filter(n=>weakES.has(n));

  const acadRows=ACAD_MAIN.map(s=>{
    const ysc=ys.filter(x=>x.subjects[s]).map(x=>x.subjects[s].score);
    const esc=es.filter(x=>x.subjects[s]).map(x=>x.subjects[s].score);
    if(!ysc.length&&!esc.length) return '';
    const ya=ysc.length?(ysc.reduce((a,b)=>a+b,0)/ysc.length).toFixed(1):'—';
    const ea=esc.length?(esc.reduce((a,b)=>a+b,0)/esc.length).toFixed(1):'—';
    const diff=ya!=='—'&&ea!=='—'?(parseFloat(ea)-parseFloat(ya)).toFixed(1):null;
    return `<tr><td>${s}</td><td><b>${ya}%</b></td><td><b>${ea}%</b></td>
      <td style="${diff>0?'color:var(--gn)':diff<0?'color:var(--rd)':''}">${diff!==null?(diff>0?'▲ ':diff<0?'▼ ':'')+Math.abs(diff)+'%':'—'}</td></tr>`;
  }).join('');

  const meta=[schoolName,gradeName].filter(Boolean).join(' | ');
  const el=document.getElementById('rptBoth');
  el.classList.remove('hidden');
  el.innerHTML=`<div class="rpt">
    <div class="rpt-hdr" style="background:var(--pu)">
      <h2>🔀 مقارنة أعمال السنة ونهاية الفصل</h2>
      <span class="meta">${meta}</span>
    </div>
    <div class="rpt-body">
      <div class="sc-grid">
        <div class="sc gd"><div class="sc-l">متوسط أعمال السنة</div><div class="sc-v">${avgYS}%</div></div>
        <div class="sc gn"><div class="sc-l">متوسط نهاية الفصل</div><div class="sc-v">${avgES}%</div></div>
        <div class="sc"><div class="sc-l">الفرق</div><div class="sc-v">${Math.abs(avgYS-avgES).toFixed(1)}%</div>
          <div class="sc-n">${parseFloat(avgES)>parseFloat(avgYS)?'نهاية الفصل أعلى':'أعمال السنة أعلى'}</div></div>
        <div class="sc gd"><div class="sc-l">تفوق في الاثنين</div><div class="sc-v">${bothTop.length}</div><div class="sc-n">طالب</div></div>
        <div class="sc rd"><div class="sc-l">ضعف في الاثنين</div><div class="sc-v">${bothWeak.length}</div><div class="sc-n">يحتاج دعماً</div></div>
      </div>
      ${bothTop.length?`<div class="sec">🏆 تفوقوا في التقريرين معاً</div>
      <div style="display:flex;flex-wrap:wrap;gap:6px;margin-bottom:12px">
        ${bothTop.map(n=>`<span style="background:#e8f5ee;border:1px solid var(--gn);padding:3px 10px;border-radius:10px;font-size:12px;font-weight:600">${n}</span>`).join('')}
      </div>`:''}
      ${bothWeak.length?`<div class="sec">⚠️ يحتاجون دعماً في التقريرين</div>
      <div style="display:flex;flex-wrap:wrap;gap:6px;margin-bottom:12px">
        ${bothWeak.map(n=>`<span style="background:#fdf2f0;border:1px solid var(--rd);padding:3px 10px;border-radius:10px;font-size:12px;color:var(--rd);font-weight:600">${n}</span>`).join('')}
      </div>`:''}
      <div class="sec">📊 مقارنة المواد الأساسية</div>
      <div style="overflow-x:auto"><table class="stbl">
        <thead><tr><th>المادة</th><th>أعمال السنة</th><th>نهاية الفصل</th><th>الفرق</th></tr></thead>
        <tbody>${acadRows}</tbody></table></div>
      <div class="ch-grid" style="margin-top:12px">
        <div class="ch-card ch-full"><h4>مقارنة متوسطات المواد الأساسية</h4>
          <div class="ch-wrap ch-h160"><canvas id="both-chC"></canvas></div></div>
      </div>
    </div>
  </div>`;
  setTimeout(()=>{
    const labels=[...new Set([...ACAD_MAIN.filter(s=>parsed.ys.subjects.includes(s)),...ACAD_MAIN.filter(s=>parsed.es.subjects.includes(s))])];
    const ysD=labels.map(s=>{const sc=ys.filter(x=>x.subjects[s]).map(x=>x.subjects[s].score);return sc.length?(sc.reduce((a,b)=>a+b,0)/sc.length).toFixed(1):0;});
    const esD=labels.map(s=>{const sc=es.filter(x=>x.subjects[s]).map(x=>x.subjects[s].score);return sc.length?(sc.reduce((a,b)=>a+b,0)/sc.length).toFixed(1):0;});
    const ce=document.getElementById('both-chC');
    if(ce) CH.both.cmp=new Chart(ce,{type:'bar',
      data:{labels,datasets:[
        {label:'أعمال السنة',data:ysD,backgroundColor:'rgba(200,151,58,.8)',borderRadius:5},
        {label:'نهاية الفصل',data:esD,backgroundColor:'rgba(29,92,110,.8)',borderRadius:5}]},
      options:{responsive:true,maintainAspectRatio:false,
        plugins:{legend:{position:'bottom',labels:{font:{family:'Tajawal',size:11}}}},
        scales:{x:{ticks:{font:{family:'Tajawal',size:10}}},y:{min:0,max:100,ticks:{font:{family:'Tajawal'}}}}}});
  },80);
}

/* ════ UTILS ════ */
function showTab(t,id,btn){
  const el=document.getElementById(t==='ys'?'rptYS':'rptES');
  el.querySelectorAll('.tc').forEach(x=>x.classList.remove('on'));
  el.querySelectorAll('.tab').forEach(x=>x.classList.remove('on'));
  document.getElementById(t+'-'+id).classList.add('on');
  btn.classList.add('on');
  if(id==='det') filterDet(t);
}
function destroyCH(t){Object.values(CH[t]||{}).forEach(c=>{try{c.destroy()}catch(e){}});CH[t]={};}
function resetAll(){
  raw.ys=null;raw.es=null;parsed.ys=null;parsed.es=null;schoolName='';gradeName='';
  ['ys','es','both'].forEach(t=>destroyCH(t));
  ['YS','ES'].forEach(k=>{
    document.getElementById('dz'+k).classList.remove('loaded');
    const l=document.getElementById('lbl'+k);l.textContent='اضغط أو اسحب الملف';l.classList.remove('ok');
    document.getElementById('btn'+k).disabled=true;document.getElementById('btn'+k).classList.remove('on');
    document.getElementById('f'+k).value='';
  });
  document.getElementById('btnBoth').disabled=true;document.getElementById('btnBoth').classList.remove('on');
  document.getElementById('rptYS').classList.add('hidden');
  document.getElementById('rptES').classList.add('hidden');
  document.getElementById('rptBoth').classList.add('hidden');
  document.getElementById('btnPrint').disabled=true;
  document.getElementById('iSchool').value='';
  document.getElementById('iGrade').value='';
}
</script>
</body>
