}

function setOrient(o){
  printOrient=o;
  document.getElementById('oPortrait').classList.toggle('sel',o==='portrait');
  document.getElementById('oLandscape').classList.toggle('sel',o==='landscape');
}

function doPrint(){
  const checks=[...document.querySelectorAll('#printSections input[type=checkbox]')].filter(c=>c.checked);
  if(!checks.length){ alert('اختر قسماً واحداً على الأقل'); return; }
  const selected=checks.map(c=>c.value);
  const hasDet   = selected.some(v=>v.endsWith('-det'));
  const hasCover = selected.includes('cover-page');

  // إعادة ضبط كل شيء
  document.querySelectorAll('.tc').forEach(el=>el.classList.remove('print-include'));
  ['rptYS','rptES','rptBoth'].forEach(id=>document.getElementById(id).setAttribute('data-print','hide'));
  document.getElementById('coverPage').setAttribute('data-print', hasCover?'show':'hide');

  // بناء الغلاف
  if(hasCover) buildCover(selected);

  selected.forEach(val=>{
    if(val==='cover-page') return;
    if(val==='both-rpt'){
      document.querySelectorAll('#rptBoth .tc').forEach(tc=>tc.classList.add('print-include'));
      document.getElementById('rptBoth').setAttribute('data-print','show');
    } else {
      const parts=val.split('-'), id=parts.pop(), t=parts.join('-');
      const el=document.getElementById(t+'-'+id);
      if(el){
        el.classList.add('print-include');
        document.getElementById(t==='ys'?'rptYS':'rptES').setAttribute('data-print','show');
      }
    }
  });

  // اتجاه: الكشف أفقي دائماً إذا كان مختاراً، وإلا حسب اختيار المستخدم
  const orient = hasDet ? 'landscape' : printOrient;

  let styleEl=document.getElementById('_pstyle');
  if(!styleEl){styleEl=document.createElement('style');styleEl.id='_pstyle';document.head.appendChild(styleEl);}
  // إذا كان الكشف والغلاف معاً، نطبع الغلاف بصفحة منفصلة portrait
  // ثم الباقي بالاتجاه المختار
  // الحل: نستخدم @page مع named pages لكنها محدودة الدعم
  // الحل الأبسط والأضمن: إذا الكشف مختار → portrait فقط مع font صغير
  // إذا الكشف فقط → landscape

  const detOnly = selected.filter(v=>v!=='cover-page').every(v=>v.endsWith('-det'));
  const finalOrient = detOnly ? 'landscape' : 'portrait';

  styleEl.textContent=`
    @media print {
      @page { size: A4 ${finalOrient}; margin: ${finalOrient==='landscape'?'6mm 5mm':'12mm 10mm'}; }
      [data-print="hide"] { display: none !important; }
      [data-print="show"] { display: block !important; }
      .cover-page {
        height: ${finalOrient==='landscape'?'190mm':'265mm'};
        max-height: ${finalOrient==='landscape'?'190mm':'265mm'};
      }
      ${hasDet ? `.tc.print-include.det-section .dtbl{font-size:${finalOrient==='landscape'?'8px':'7px'};}
      .tc.print-include.det-section .dtbl th,
      .tc.print-include.det-section .dtbl td{padding:${finalOrient==='landscape'?'3px 4px':'2px 3px'};white-space:nowrap;}
      .tc.print-include.det-section .dtbl-wrap{overflow:visible;}
      .tc.print-include.det-section .dtbl thead th{background:#1a3a4a!important;-webkit-print-color-adjust:exact;print-color-adjust:exact;}` : ''}
    }
  `;

  closePrintDialog();
  setTimeout(()=>{
    window.print();
    setTimeout(()=>{
      document.querySelectorAll('.tc').forEach(el=>el.classList.remove('print-include'));
      ['rptYS','rptES','rptBoth','coverPage'].forEach(id=>document.getElementById(id).removeAttribute('data-print'));
    },800);
  },200);
}

function buildCover(selected){
  // استخرج التقارير المختارة
  const reports=[];
  if(selected.some(v=>v.startsWith('ys-'))&&parsed.ys) reports.push({t:'ys',label:'أعمال السنة',d:parsed.ys});
  if(selected.some(v=>v.startsWith('es-'))&&parsed.es) reports.push({t:'es',label:'نهاية الفصل',d:parsed.es});

  const title = reports.length===2?'تقرير الدرجات — أعمال السنة ونهاية الفصل':
                reports.length===1?'تقرير '+reports[0].label:
                'تقرير الدرجات';

  document.getElementById('cvSchool').textContent = schoolName || 'اسم المدرسة';
  document.getElementById('cvGrade').textContent  = gradeName  || '';
  document.getElementById('cvTitle').textContent  = title;
  document.getElementById('cvYear').textContent   = document.getElementById('year')?.value || '';

  // إحصائيات موجزة
  const statsEl=document.getElementById('cvStats');
  statsEl.innerHTML=reports.map(r=>{
    const n=r.d.students.length;
    const avg=(r.d.students.reduce((a,b)=>a+b.avg,0)/n).toFixed(1);
    const ex=r.d.students.filter(s=>s.generalGrade==='ممتاز').length;
    return `<div class="cover-stat">
      <span class="cv">${n}</span><span class="cl">${r.label}</span>
    </div>
    <div class="cover-stat">
      <span class="cv">${avg}%</span><span class="cl">متوسط ${r.label}</span>
    </div>
    <div class="cover-stat">
      <span class="cv">${ex}</span><span class="cl">ممتاز ${r.label}</span>
    </div>`;
  }).join('<div style="width:1px;background:#d4dde4;margin:0 4mm"></div>');
}

/* ════════════════════════════════════════════
   قراءة الخلايا مباشرة بالعنوان — أضمن طريقة
   الخريطة مؤكدة 100% من Python
════════════════════════════════════════════ */
function cellVal(ws, addr) {
  const cell = ws[addr];
  if (!cell) return null;
  // v = raw value, w = formatted string
  return cell.v !== undefined ? cell.v : null;
}
function cellStr(ws, addr) {
  const v = cellVal(ws, addr);
  return v !== null && v !== undefined ? String(v).trim() : '';
}
function cellNum(ws, addr) {
  const v = cellVal(ws, addr);
  if (v === null || v === undefined) return 0;
  if (typeof v === 'number') return v;
  return parseFloat(String(v).replace(/[^\d.]/g, '')) || 0;
}

/* ════ عناوين الخلايا المحددة ════ */
// أعمال السنة (ys):
//   اسم المدرسة العربي: AE25  | الصف: P19
//   اسم الطالب: AK27          | الفصل: AB27
//   مواد: صفوف 34-44, اسم=AU, درجة=AJ, تقدير=W
//   الترتيب: G51
//
// نهاية الفصل (es):
//   اسم المدرسة: AE26          | الصف: J19
//   اسم الطالب: AJ28           | الفصل: AB28
//   مواد: صفوف 35-47, اسم=AV, درجة=AI, تقدير=X
//   المعدل: X49 | التقدير: AL50 | الترتيب: G56

const SUBJ_ROWS = {
  ys: {start:34, end:44, nameCol:'AU', scoreCol:'AJ', gradeCol:'W'},
  es: {start:35, end:47, nameCol:'AV', scoreCol:'AI', gradeCol:'X'}
};

const SKIP_SUBJ  = new Set(['المواظبة','السلوك']);
const ACAD_EXCL  = new Set(['التربية البدنية والدفاع عن النفس','التربية الفنية','النشاط','المهارات الحياتية والأسرية','المهارات الرقمية']);
const ACAD_MAIN  = ['الرياضيات','العلوم','اللغة العربية','اللغة الإنجليزية','القرآن الكريم والدراسات الإسلامية'];

/* ════ STATE ════ */
const raw    = {ys:null, es:null};
const parsed = {ys:null, es:null};
const CH     = {ys:{}, es:{}, both:{}};
let   schoolName = '', gradeName = '';

/* ════ FILE LOAD ════ */
function doDrop(e,t){
  e.preventDefault();
  document.getElementById(t==='ys'?'dzYS':'dzES').classList.remove('drag');
  if(e.dataTransfer.files[0]) loadBuf(e.dataTransfer.files[0],t);
}
function onFile(inp,t){ if(inp.files[0]) loadBuf(inp.files[0],t); }
function loadBuf(file,t){
  const r=new FileReader();
  r.onload=e=>{
    raw[t]=e.target.result;
    document.getElementById(t==='ys'?'dzYS':'dzES').classList.add('loaded');
    const lbl=document.getElementById(t==='ys'?'lblYS':'lblES');
    lbl.textContent='✅ '+file.name;
    lbl.classList.add('ok');
    document.getElementById(t==='ys'?'btnYS':'btnES').disabled=false;
    document.getElementById(t==='ys'?'btnYS':'btnES').classList.add('on');
    if(raw.ys&&raw.es){
      document.getElementById('btnBoth').disabled=false;
      document.getElementById('btnBoth').classList.add('on');
    }
    // استخراج اسم المدرسة والصف مسبقاً
    previewMeta(e.target.result, t);
  };
  r.readAsArrayBuffer(file);
}

function previewMeta(buffer, type){
  try{
    const wb = XLSX.read(buffer,{type:'array'});
    const ws = wb.Sheets[wb.SheetNames[0]];
    // اسم المدرسة
    const school = type==='ys'
      ? (cellStr(ws,'AE25') || cellStr(ws,'E25'))
      : (cellStr(ws,'AE26') || cellStr(ws,'E26'));
    const grade = type==='ys'
      ? (cellStr(ws,'P19') || cellStr(ws,'Q19'))
      : (cellStr(ws,'J19') || cellStr(ws,'J20'));
    if(school) schoolName = school;
    if(grade)  gradeName  = grade;
    document.getElementById('iSchool').value = schoolName || '';
    document.getElementById('iGrade').value  = gradeName  || '';
  }catch(e){}
}

/* ════ PARSE ════ */
function parseFile(buffer, type){
  const wb = XLSX.read(buffer,{type:'array'});
  const students=[], subjSet=new Set();
  const sr = SUBJ_ROWS[type];

  for(const sn of wb.SheetNames){
    const ws = wb.Sheets[sn];

    // اسم الطالب
    const nameAddr = type==='ys' ? 'AK27' : 'AJ28';
    const nameRaw  = cellStr(ws, nameAddr);
    if(!nameRaw) continue;
    const name = nameRaw.replace(/^اسم الطالب\s*[:\s]+/,'').trim();
    if(!name || name.length<3) continue;

    // الفصل
    const classNum = cellStr(ws, type==='ys'?'AB27':'AB28');

    // المواد
    const subjects = {};
    for(let row=sr.start; row<=sr.end; row++){
      const sname = cellStr(ws, sr.nameCol+row);
      const score = cellNum(ws, sr.scoreCol+row);
      const grade = cellStr(ws, sr.gradeCol+row);
      if(!sname) continue;
      const sn2 = sname.trim();
      if(SKIP_SUBJ.has(sn2)) continue;
      if(score > 0){
        subjects[sn2] = {score, grade};
        subjSet.add(sn2);
      }
    }
    if(!Object.keys(subjects).length) continue;

    // المعدل والتقدير
    let avg=0, total=0, generalGrade='';
    if(type==='es'){
      const avgRaw = cellStr(ws,'X49');
      avg   = parseFloat(avgRaw.replace('%','').replace(/[^\d.]/g,'')) || 0;
      total = cellNum(ws,'X48');
      generalGrade = cellStr(ws,'AL50') || gradeLabel(avg);
    } else {
      const acadScores = Object.entries(subjects)
        .filter(([k])=>!ACAD_EXCL.has(k))
        .map(([,v])=>v.score);
      if(acadScores.length){
        total = acadScores.reduce((a,b)=>a+b,0);
        avg   = Math.round(total/acadScores.length*10)/10;
      }
      generalGrade = gradeLabel(avg);
    }

    const gradeRank = cellNum(ws, type==='ys'?'G51':'G56');
    students.push({name,classNum,avg,total,generalGrade,gradeRank,subjects});
  }

  students.sort((a,b)=>b.avg-a.avg);
  return {students, subjects: Array.from(subjSet)};
}

function gradeLabel(v){return v>=90?'ممتاز':v>=75?'جيد جداً':v>=60?'جيد':v>=50?'مقبول':'ضعيف';}
function gpCls(g){return{ممتاز:'ex','جيد جداً':'vg',جيد:'gd2',مقبول:'ac',ضعيف:'fl'}[g]||'fl';}

/* ════ RUN ════ */
function runReport(type){
  try{
    if(type==='ys'||type==='both') parsed.ys = parseFile(raw.ys,'ys');
    if(type==='es'||type==='both') parsed.es = parseFile(raw.es,'es');
  } catch(e){ alert('خطأ: '+e.message); return; }

  if(type==='ys'||type==='both'){ destroyCH('ys'); buildReport('ys'); }
  if(type==='es'||type==='both'){ destroyCH('es'); buildReport('es'); }
  if(type==='both'){ destroyCH('both'); buildBoth(); }

  document.getElementById('btnPrint').disabled=false;
  const scrollTarget = type==='es'?'rptES':type==='both'?'rptYS':'rptYS';
  setTimeout(()=>document.getElementById(scrollTarget).scrollIntoView({behavior:'smooth'}),200);
}

